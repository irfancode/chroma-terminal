}

THEME_NAMES=(monokai-pro octagon ristretto spectrum machine classic zen protorium relaxed amber)
THEME_DISPLAY=("Monokai Pro" "Filter Octagon" "Filter Ristretto" "Filter Spectrum" "Filter Machine" "Monokai Classic" "Filter Zen" "Filter Protorium" "Filter Relaxed" "Filter Amber")

declare -A T_IDX
for i in "${!THEME_NAMES[@]}"; do T_IDX["${THEME_NAMES[$i]}"]="$i"; done

# ──────────────────────────────────────────────
# Preview
# ──────────────────────────────────────────────
show_preview() {
  local theme="$1"
  echo ""
  log_title "${THEME_DISPLAY[${T_IDX[$theme]}]}"
  echo ""
  printf "  ${BOLD}Background:${RESET}  "
  printf "\033[48;2;%d;%d;%dm              ${RESET}\n" \
    "$(printf '%d' 0x$(echo ${T_BG[$theme]:1} | cut -c1-2))" \
    "$(printf '%d' 0x$(echo ${T_BG[$theme]:1} | cut -c3-4))" \
    "$(printf '%d' 0x$(echo ${T_BG[$theme]:1} | cut -c5-6))"
  printf "  ${BOLD}Foreground:${RESET}  "
  printf "\033[48;2;%d;%d;%dm              ${RESET}\n" \
    "$(printf '%d' 0x$(echo ${T_FG[$theme]:1} | cut -c1-2))" \
    "$(printf '%d' 0x$(echo ${T_FG[$theme]:1} | cut -c3-4))" \
    "$(printf '%d' 0x$(echo ${T_FG[$theme]:1} | cut -c5-6))"
  echo ""
  printf "  ${BOLD}Palette:${RESET}\n"
  local colors=("${T_BLK[$theme]}" "${T_RED[$theme]}" "${T_GRN[$theme]}" "${T_YLW[$theme]}" "${T_BLU[$theme]}" "${T_MAG[$theme]}" "${T_CYN[$theme]}" "${T_WHI[$theme]}")
  printf "  "
  for c in "${colors[@]}"; do
    printf "\033[48;2;%d;%d;%dm  ${RESET} " \
      "$(printf '%d' 0x$(echo $c | cut -c2-3))" \
      "$(printf '%d' 0x$(echo $c | cut -c4-5))" \
      "$(printf '%d' 0x$(echo $c | cut -c6-7))"
  done
  printf "\n  ${DIM}%-6s${RESET} ${DIM}%-6s${RESET} ${DIM}%-6s${RESET} ${DIM}%-6s${RESET} ${DIM}%-6s${RESET} ${DIM}%-6s${RESET} ${DIM}%-6s${RESET} ${DIM}%-6s${RESET}\n" \
    "Black" "Red" "Green" "Yellow" "Blue" "Magenta" "Cyan" "White"
  echo ""
}

# ──────────────────────────────────────────────
# Download helpers
# ──────────────────────────────────────────────
download_and_run() {
  local script="$1" dest="$2"
  mkdir -p "$(dirname "$dest")"
  if has_cmd curl; then
    curl -fsSL "${RAW_BASE}/scripts/${script}" -o "$dest" || return 1
  elif has_cmd wget; then
    wget -q "${RAW_BASE}/scripts/${script}" -O "$dest" || return 1
  else
    return 1
  fi
  chmod +x "$dest"
  return 0
}

download_file() {
  local path="$1" dest="$2"
  mkdir -p "$(dirname "$dest")"
  if has_cmd curl; then
    curl -fsSL "${RAW_BASE}/${path}" -o "$dest" || return 1
  elif has_cmd wget; then
    wget -q "${RAW_BASE}/${path}" -O "$dest" || return 1
  else
    return 1
  fi
  return 0
}

# ──────────────────────────────────────────────
# Backup existing configs
# ──────────────────────────────────────────────
backup_configs() {
  local backup_dir="${HOME}/.monokai-pro-terminal-backup-$(date +%Y%m%d%H%M%S)"
  local has_backup=false

  for f in "${HOME}/.config/starship.toml" "${HOME}/.config/ghostty/config" "${HOME}/.config/alacritty/alacritty.toml" "${HOME}/.config/kitty/kitty.conf" "${HOME}/.config/foot/foot.ini"; do
    if [[ -f "$f" ]]; then
      mkdir -p "$backup_dir"
      cp "$f" "$backup_dir/" 2>/dev/null && has_backup=true
    fi
  done

  if $has_backup; then
    log_info "Backed up existing configs to ${backup_dir}"
  fi
}

# ──────────────────────────────────────────────
# OS detection
# ──────────────────────────────────────────────
detect_os() {
  case "$(uname -s)" in
    Linux*)  echo "linux" ;;
    Darwin*) echo "macos" ;;
    *)       echo "unknown" ;;
  esac
}

# ──────────────────────────────────────────────
# Main
# ──────────────────────────────────────────────
main() {
  init_themes

  local theme=""
  local do_font=false
  local do_prompt=false
  local do_tools=false
  local do_all=false

  # Parse flags
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --theme)
        shift
        theme="$1"
        ;;
      --font)     do_font=true ;;
      --prompt)   do_prompt=true ;;
      --tools)    do_tools=true ;;
      --all)      do_all=true ;;
      --list-themes)
        echo ""
        log_title "Available Themes"
        echo ""
        for i in "${!THEME_NAMES[@]}"; do
          printf "  ${BOLD}%-16s${RESET} %s\n" "${THEME_NAMES[$i]}" "${THEME_DISPLAY[$i]}"
        done
        echo ""
        exit 0
        ;;
      --preview)
        if [[ -n "${2:-}" && ! "$2" =~ ^-- ]]; then
          local ptheme="$2"
          shift
          if [[ -n "${T_IDX[$ptheme]:-}" ]]; then
            show_preview "$ptheme"
          else
            log_error "Unknown theme: $ptheme"
            exit 1
          fi
        else
          for n in "${THEME_NAMES[@]}"; do show_preview "$n"; done
        fi
        exit 0
        ;;
      --help|-h)
        sed -n '3,16p' "$0" | sed 's/^# //; s/^#$//'
        exit 0
        ;;
      *)
        log_error "Unknown option: $1"
        echo "Usage: monokai-pro-cli [--theme <name>] [--font] [--prompt] [--tools] [--all] [--list-themes] [--preview] [--help]"
        exit 1
        ;;
    esac
    shift
  done

  # Validate theme
  if [[ -n "$theme" ]]; then
    if [[ -z "${T_IDX[$theme]:-}" ]]; then
      log_error "Unknown theme: ${theme}"
      echo "Available themes: ${THEME_NAMES[*]}"
      exit 1
    fi
  fi

  local os
  os="$(detect_os)"
  if [[ "$os" == "unknown" ]]; then
    log_error "Unsupported OS: $(uname -s)"
    exit 1
  fi

  # Interactive mode
  if [[ -z "$theme" ]] && ! $do_all; then
    echo ""
    log_title "╔══════════════════════════════════════╗"
    log_title "║  Monokai Pro Terminal Quick Setup     ║"
    log_title "╚══════════════════════════════════════╝"
    echo ""

    log_title "Select a theme:"
    echo ""
    for i in "${!THEME_NAMES[@]}"; do
      printf "  ${BOLD}%2d)${RESET} %-16s ${DIM}%s${RESET}\n" $((i + 1)) "${THEME_NAMES[$i]}" "${THEME_DISPLAY[$i]}"
    done
    echo ""
    read -r -p "$(printf "${BOLD}Enter theme number or name [1]:${RESET} ")" choice
    choice="${choice:-1}"

    if [[ "$choice" =~ ^[0-9]+$ ]] && [[ "$choice" -ge 1 ]] && [[ "$choice" -le ${#THEME_NAMES[@]} ]]; then
      theme="${THEME_NAMES[$((choice - 1))]}"
    elif [[ -n "${T_IDX[$choice]:-}" ]]; then
      theme="$choice"
    else
      theme="${THEME_NAMES[0]}"
      log_warn "Using default: ${theme}"
    fi

    show_preview "$theme"
    echo ""

    if confirm "Install JetBrainsMono Nerd Font?"; then do_font=true; fi
    if confirm "Install Starship prompt?"; then do_prompt=true; fi
    if confirm "Install CLI tools (eza, bat, fd, ripgrep, zoxide, fzf)?"; then do_tools=true; fi
  fi

  if $do_all; then
    do_font=true
    do_prompt=true
    do_tools=true
    [[ -z "$theme" ]] && theme="${THEME_NAMES[0]}"
    show_preview "$theme"
  fi

  # Generate config dir
  local cache_dir="${HOME}/.cache/monokai-pro-terminal"
  mkdir -p "$cache_dir"

  # Backup existing configs
  backup_configs

  # Download and run bootstrap
  echo ""
  log_step "Downloading bootstrap script"
  if download_and_run "bootstrap.sh" "${cache_dir}/bootstrap.sh"; then
    log_ok "Bootstrap script downloaded"
  else
    log_error "Failed to download bootstrap script. Check your internet connection."
    exit 1
  fi

  # Download starship config
  if $do_prompt; then
    log_step "Downloading Starship config"
    download_file "scripts/starship.toml" "${cache_dir}/starship.toml" || log_warn "Could not pre-download starship.toml"
  fi

  # Run bootstrap with accumulated options
  local bootstrap_args=("$theme")
  $do_font   && bootstrap_args+=("--font")
  $do_prompt && bootstrap_args+=("--prompt")
  $do_tools  && bootstrap_args+=("--tools")

  echo ""
  log_step "Running bootstrap..."
  bash "${cache_dir}/bootstrap.sh" "${bootstrap_args[@]}"

  echo ""
  log_title "╔════════════════════════════════════════════╗"
  log_title "║  All done! 🎉                              ║"
  log_title "╚════════════════════════════════════════════╝"
  echo ""
  log_info "Theme: ${BOLD}${THEME_DISPLAY[${T_IDX[$theme]}]}${RESET}"
  log_info "To source Starship: exec \$SHELL"
  echo ""
}

main "$@"
