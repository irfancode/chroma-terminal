#!/usr/bin/env bash
#
# monokai-pro-cli — Single command setup for Monokai Pro Terminal
#
# Usage: bash -c "$(curl -fsSL https://raw.githubusercontent.com/irfancode/monokai-pro-terminal/main/utility/monokai-pro-cli)"
#   or:  curl -fsSL https://raw.githubusercontent.com/irfancode/monokai-pro-terminal/main/utility/monokai-pro-cli | bash
#
# Flags:
#   --theme <name>     Select theme (monokai-pro, octagon, ristretto, spectrum,
#                      machine, classic, zen, protorium, relaxed, amber)
#   --font             Install JetBrainsMono Nerd Font
#   --prompt           Install Starship prompt with Monokai Pro config
#   --tools            Install CLI tools (eza, bat, fd, ripgrep, zoxide, fzf)
#   --all              Install everything (font + prompt + tools + theme)
#   --list-themes      List all available themes with preview
#   --preview [theme]  Show color preview of a theme (or all if no theme given)
#   --help             Show this message
#
# Interactive mode is used when no flags are provided.
#

set -euo pipefail

# ──────────────────────────────────────────────
# Configuration
# ──────────────────────────────────────────────
REPO_OWNER="irfancode"
REPO_NAME="monokai-pro-terminal"
REPO_BRANCH="main"
RAW_BASE="https://raw.githubusercontent.com/${REPO_OWNER}/${REPO_NAME}/${REPO_BRANCH}"

# ──────────────────────────────────────────────
# Color helpers
# ──────────────────────────────────────────────
RESET='\033[0m'
BOLD='\033[1m'
DIM='\033[2m'
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[0;37m'

log_info()  { printf "${BLUE}  ⓘ${RESET} %s\n" "$*"; }
log_ok()    { printf "${GREEN}  ✔${RESET} %s\n" "$*"; }
log_warn()  { printf "${YELLOW}  ⚠${RESET} %s\n" "$*"; }
log_error() { printf "${RED}  ✘${RESET} %s\n" "$*" >&2; }
log_step()  { printf "\n${BOLD}${CYAN}▸ %s${RESET}\n" "$*"; }
log_title() { printf "\n${BOLD}${WHITE}  %s${RESET}\n" "$*"; }

has_cmd() { command -v "$1" &>/dev/null; }

confirm() {
  local prompt="$1" default="${2:-y}"
  local yn
  [[ "$default" == "y" ]] && prompt="$prompt [Y/n] " || prompt="$prompt [y/N] "
  read -r -p "$(printf "${BOLD}${prompt}${RESET}")" yn
  yn="${yn:-$default}"
  [[ "$yn" =~ ^[Yy]$ ]]
}

# ──────────────────────────────────────────────
# Theme definitions (embedded for offline use)
# ──────────────────────────────────────────────
declare -A T_BG T_FG T_BLK T_RED T_GRN T_YLW T_BLU T_MAG T_CYN T_WHI T_BRB T_COM

