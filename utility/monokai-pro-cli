  t="octagon"; T_BG[$t]="#2D2A2E"; T_FG[$t]="#FCFCFA"; T_BLK[$t]="#2D2A2E"; T_RED[$t]="#FF6188"; T_GRN[$t]="#A9DC76"; T_YLW[$t]="#FFD866"; T_BLU[$t]="#78DCE8"; T_MAG[$t]="#FC9867"; T_CYN[$t]="#78DCE8"; T_WHI[$t]="#FCFCFA"; T_BRB[$t]="#1A1A1C"; T_COM[$t]="#69676C"
  t="ristretto"; T_BG[$t]="#2B2A2B"; T_FG[$t]="#FCFCFA"; T_BLK[$t]="#2B2A2B"; T_RED[$t]="#E36A6A"; T_GRN[$t]="#98C379"; T_YLW[$t]="#E5C07B"; T_BLU[$t]="#7CB7D9"; T_MAG[$t]="#C678DD"; T_CYN[$t]="#56B6C2"; T_WHI[$t]="#FCFCFA"; T_BRB[$t]="#1A1A1C"; T_COM[$t]="#5C5C5C"
  t="spectrum"; T_BG[$t]="#2D2A2E"; T_FG[$t]="#FCFCFA"; T_BLK[$t]="#2D2A2E"; T_RED[$t]="#FF6188"; T_GRN[$t]="#A9DC76"; T_YLW[$t]="#FFD866"; T_BLU[$t]="#78DCE8"; T_MAG[$t]="#FC9867"; T_CYN[$t]="#AB9DF2"; T_WHI[$t]="#FCFCFA"; T_BRB[$t]="#1A1A1C"; T_COM[$t]="#69676C"
  t="machine"; T_BG[$t]="#2D2A2E"; T_FG[$t]="#FCFCFA"; T_BLK[$t]="#2D2A2E"; T_RED[$t]="#FF6188"; T_GRN[$t]="#A9DC76"; T_YLW[$t]="#FFD866"; T_BLU[$t]="#78DCE8"; T_MAG[$t]="#AB9DF2"; T_CYN[$t]="#FC9867"; T_WHI[$t]="#FCFCFA"; T_BRB[$t]="#1A1A1C"; T_COM[$t]="#69676C"
  t="classic"; T_BG[$t]="#272822"; T_FG[$t]="#F8F8F2"; T_BLK[$t]="#272822"; T_RED[$t]="#F92672"; T_GRN[$t]="#A6E22E"; T_YLW[$t]="#E6DB74"; T_BLU[$t]="#66D9EF"; T_MAG[$t]="#AE81FF"; T_CYN[$t]="#A1EFE4"; T_WHI[$t]="#F8F8F2"; T_BRB[$t]="#1B1C18"; T_COM[$t]="#75715E"
  t="zen"; T_BG[$t]="#2D2A2E"; T_FG[$t]="#FCFCFA"; T_BLK[$t]="#2D2A2E"; T_RED[$t]="#FF6188"; T_GRN[$t]="#A9DC76"; T_YLW[$t]="#FFD866"; T_BLU[$t]="#78DCE8"; T_MAG[$t]="#AB9DF2"; T_CYN[$t]="#FC9867"; T_WHI[$t]="#FCFCFA"; T_BRB[$t]="#1A1A1C"; T_COM[$t]="#69676C"
  t="protorium"; T_BG[$t]="#2D2A2E"; T_FG[$t]="#FCFCFA"; T_BLK[$t]="#2D2A2E"; T_RED[$t]="#FF6188"; T_GRN[$t]="#A9DC76"; T_YLW[$t]="#FFD866"; T_BLU[$t]="#78DCE8"; T_MAG[$t]="#AB9DF2"; T_CYN[$t]="#FC9867"; T_WHI[$t]="#FCFCFA"; T_BRB[$t]="#1A1A1C"; T_COM[$t]="#69676C"
  t="relaxed"; T_BG[$t]="#3A3A3A"; T_FG[$t]="#F8F8F2"; T_BLK[$t]="#3A3A3A"; T_RED[$t]="#E06C75"; T_GRN[$t]="#98C379"; T_YLW[$t]="#E5C07B"; T_BLU[$t]="#61AFEF"; T_MAG[$t]="#C678DD"; T_CYN[$t]="#56B6C2"; T_WHI[$t]="#F8F8F2"; T_BRB[$t]="#282828"; T_COM[$t]="#5C6370"
